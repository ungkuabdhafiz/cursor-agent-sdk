# Copy to ~/.cursor-agent-sdk/config.toml for global defaults.
# Optional per-repo override: <project>/.cursor-agent-sdk/config.toml

[defaults]
fast = false
model = "composer-2.5"
show_tools = true
session_name = "default"
mode = "plan"  # default mode for `chat --start-mode`
# lean = true  # same as always passing --lean (project rules only, no CodeGraph MCP)

[model]
id = "composer-2.5"
fast = false

[local]
setting_sources = ["project", "user"]
sandbox_enabled = false

# CodeGraph MCP (enabled by default; uses your current directory when you run the CLI)
[codegraph]
enabled = true
# command = "/full/path/to/codegraph"  # optional; defaults to PATH / CODEGRAPH_BIN
# no_watch = false

# Optional additional MCP servers (name "codegraph" overrides auto-injection)
# [mcp_servers.filesystem]
# type = "stdio"
# command = "npx"
# args = ["-y", "@modelcontextprotocol/server-filesystem", "/path/to/dir"]
